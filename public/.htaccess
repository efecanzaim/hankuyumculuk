<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Eğer istenen dosya varsa, doğrudan sun
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Blog detay sayfaları - Tüm /blog/* URL'lerini /blog/index.html'e yönlendir
  RewriteCond %{REQUEST_URI} ^/blog/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^blog/.+ /blog/index.html [L]

  # Ürün detay sayfaları - Tüm /urun/* URL'lerini /urun/index.html'e yönlendir
  RewriteCond %{REQUEST_URI} ^/urun/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^urun/.+ /urun/index.html [L]

  # EN - Product detail pages
  RewriteCond %{REQUEST_URI} ^/en/product/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^en/product/.+ /en/product/index.html [L]

  # EN - Blog detail pages
  RewriteCond %{REQUEST_URI} ^/en/blog/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^en/blog/.+ /en/blog/index.html [L]

  # RU - Product detail pages (tovar)
  RewriteCond %{REQUEST_URI} ^/ru/tovar/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ru/tovar/.+ /ru/tovar/index.html [L]

  # RU - Blog detail pages
  RewriteCond %{REQUEST_URI} ^/ru/blog/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ru/blog/.+ /ru/blog/index.html [L]

  # TR - Sertifika sayfaları
  RewriteCond %{REQUEST_URI} ^/sertifika/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^sertifika/.+ /sertifika/index.html [L]

  # EN - Certificate pages
  RewriteCond %{REQUEST_URI} ^/en/certificate/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^en/certificate/.+ /en/certificate/index.html [L]

  # RU - Certificate pages (sertifikat)
  RewriteCond %{REQUEST_URI} ^/ru/sertifikat/[^/]+/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ru/sertifikat/.+ /ru/sertifikat/index.html [L]

  # Trailing slash yoksa ve dizin varsa, trailing slash ekle (SEO için)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ $1/ [L,R=301]

  # Eğer istenen klasör varsa ve içinde index.html varsa, onu sun
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]

  # Eğer path/index.html varsa, onu sun (trailing slash olmadan)
  RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]

  # EN SPA fallback - /en/* için /en/index.html'e yönlendir
  RewriteCond %{REQUEST_URI} ^/en/
  RewriteRule ^en/.+ /en/index.html [L]

  # RU SPA fallback - /ru/* için /ru/index.html'e yönlendir
  RewriteCond %{REQUEST_URI} ^/ru/
  RewriteRule ^ru/.+ /ru/index.html [L]

  # Hiçbiri değilse, ana index.html'e yönlendir (SPA fallback)
  RewriteRule ^ /index.html [L]
</IfModule>
